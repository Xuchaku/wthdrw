{
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["dom", "dom.iterable", "es2022"],
		"allowJs": false,
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "preserve",
		"jsxImportSource": "react",
		"incremental": true,
		"types": [
			"vitest/globals",
			"@testing-library/jest-dom",
			"@testing-library/jest-dom/vitest"
		],
		"baseUrl": ".",
		"paths": {
			"@/*": ["src/*"]
		},
		"plugins": [
			{
				"name": "next"
			}
		]
	},
	"include": [
		"next-env.d.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"vitest.setup.ts",
		"vitest.d.ts",
		"vitest.config.ts",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
